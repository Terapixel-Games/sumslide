; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="sumslide"
config/features=PackedStringArray("4.5", "Mobile")
config/icon="res://icon.svg"
run/main_scene="res://src/scenes/Boot.tscn"

[autoload]

SaveStore="*res://src/data/SaveStore.gd"
RunManager="*res://src/core/RunManager.gd"
AdManager="*res://addons/arcade_core/AdManager.gd"
MusicManager="*res://src/audio/MusicManager.gd"
VFXManager="*res://src/vfx/VFXManager.gd"

SaveManager="*res://addons/arcade_core/SaveManager.gd"
StreakManager="*res://addons/arcade_core/StreakManager.gd"
AudioManager="*res://addons/arcade_core/AudioManager.gd"
Fx="*res://addons/arcade_core/Fx.gd"
[display]

window/size/viewport_width=1080
window/size/viewport_height=1920
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=1

window/size/resizable=true
[rendering]

renderer/rendering_method="mobile"

[sumslide]

use_mock_ads=true
ads_force_real=false
